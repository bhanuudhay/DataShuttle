# MongoDB connection URI for the auth/user database
MONGO_URI=mongodb://localhost:27017/datashuttle-users

# JWT authentication settings
JWT_SECRET=change-this-to-a-strong-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=1440

# Redis configuration (used for session management)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Allowed frontend origins (comma-separated for multiple)
CORS_ORIGINS=http://localhost:3000
